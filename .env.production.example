# Copy this file to `.env.production` before your first production-like deploy.
# Fill in real values and keep the resulting file out of git.

COMPOSE_PROJECT_NAME=limi

POSTGRES_DB=limi
POSTGRES_USER=limi
POSTGRES_PASSWORD=change-me-postgres-password

DATABASE_URL=postgres://limi:change-me-postgres-password@postgres:5432/limi?sslmode=disable
REDIS_URL=redis://redis:6379

JWT_SECRET=change-me-jwt-secret
COOKIE_SECRET=change-me-cookie-secret
COOKIE_SECURE=true

STORE_DOMAIN=storefront.local
ADMIN_DOMAIN=admin.storefront.local
API_DOMAIN=api.storefront.local

STORE_CORS=https://storefront.local
ADMIN_CORS=https://admin.storefront.local
AUTH_CORS=https://storefront.local,https://admin.storefront.local

NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.storefront.local
MEDUSA_BACKEND_URL=http://backend:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=replace-with-your-publishable-key
MEDUSA_WAIT_TIMEOUT_SECONDS=120

MEDUSA_ADMIN_HTTPS=true
RUN_SEED_ON_BOOT=false

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=change-me-smtp-password
SMTP_FROM=mailer@example.com

BANK_TRANSFER_ACCOUNT_NAME=Limi s.r.o.
BANK_TRANSFER_BANK_NAME=Slovenska sporitelna
BANK_TRANSFER_IBAN=SK00 0000 0000 0000 0000 0000
BANK_TRANSFER_SWIFT=GIBASKBX
BANK_TRANSFER_REFERENCE_PREFIX=LIMI
